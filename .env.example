# Database (direct Postgres — migrations / prisma db push)
DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/project_portal"

# App runtime via PgBouncer (recommended in production)
# DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:6432/project_portal?pgbouncer=true"

POSTGRES_DB=project_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432

# NextAuth
NEXTAUTH_URL="https://manexa.example.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Cron / background jobs
CRON_SECRET="generate-with-openssl-rand-base64-32"
# DISABLE_IN_PROCESS_CRON=true  # use external worker when running multiple PM2 instances

# Redis (Socket.IO adapter, rate limiting, очередь экспорта УПД — обязателен в production)
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# Асинхронный экспорт УПД (BullMQ + отдельный воркер)
# npm run worker:export  или  docker compose up -d document-export-worker
DOCUMENT_EXPORT_WORKER_CONCURRENCY=3
# DOCUMENT_EXPORT_WORKER_INSTANCES=2
# DOCUMENT_EXPORT_RATE_LIMIT_USER=15
# DOCUMENT_EXPORT_RATE_LIMIT_COMPANY=120
# DOCUMENT_EXPORT_QUEUE_ATTEMPTS=3

# MinIO / S3 (MINIO_ACCESS_KEY = MINIO_ROOT_USER for app code)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local_dev
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_local_dev
MINIO_ENDPOINT=http://localhost:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET=manexa-documents

# PDF УПД: конвертация из Excel (тот же шаблон ФНС). Запуск: docker compose up -d gotenberg
GOTENBERG_URL=http://localhost:3001
GOTENBERG_PORT=3001

# Server
HOST=0.0.0.0
PORT=3000
# PM2_INSTANCES=1
# APP_INTERNAL_URL=http://127.0.0.1:3000  # cron worker / internal health checks

# Email (optional — invite emails, alert notifications)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_SECURE=false
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@yourcompany.com"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# App URLs
NEXT_PUBLIC_APP_URL="https://manexa.example.com"

# Registration (public self-signup)
# Production default: disabled unless explicitly enabled
# ALLOW_PUBLIC_REGISTRATION=false
# NEXT_PUBLIC_ALLOW_PUBLIC_REGISTRATION=false

# Security / diagnostics
# ALLOW_DEBUG_ROUTES=false
# HEALTH_PUBLIC=false

# Monitoring & alerts
# ALERTS_ENABLED=true
# ALERT_EMAIL=ops@yourcompany.com
# ALERT_WEBHOOK=https://hooks.example.com/manexa
# ALERT_ERROR_RATE=5
# ALERT_RESPONSE_TIME=2000
# ALERT_MEMORY_USAGE=80

# Error tracking (optional — npm install @sentry/node)
# SENTRY_DSN=https://example@sentry.io/project

# CDN for MinIO public assets (future use)
# CDN_BASE_URL=https://cdn.manexa.example.com
